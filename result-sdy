<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Data SDY 2026</title>

<style>
body{
    font-family:Arial,Helvetica,sans-serif;
    background:#f5f5f5;
}

.container{
    max-width:980px;
    margin:30px auto;
}

h1{
    text-align:center;
    font-size:54px;
    margin-bottom:30px;
    color:#333;
}

table{
    width:100%;
    border-collapse:collapse;
    background:#fff;
}

thead th{
    background:#b57a00;
    color:#fff;
    font-size:22px;
    padding:15px;
    border:1px solid #d8d8d8;
}

tbody td{
    text-align:center;
    font-size:22px;
    padding:14px;
    border:1px solid #ddd;
}
</style>
</head>
<body>

<div class="container">

<h1>Data SDY 2026</h1>

<table>
<thead>
<tr>
    <th>SNIN</th>
    <th>SLSA</th>
    <th>RABU</th>
    <th>KMIS</th>
    <th>JMAT</th>
    <th>SBTU</th>
    <th>MGGU</th>
</tr>
</thead>

<tbody id="hasil"></tbody>

</table>

</div>

<script>
fetch("result-togel/sdy.js")
.then(r=>r.json())
.then(data=>{
    const tbody=document.getElementById("hasil");
    tbody.innerHTML=data.map(row=>
        `<tr>${row.map(n=>`<td>${String(n).padStart(4,'0')}</td>`).join("")}</tr>`
    ).join("");
});
</script>

</body>
</html>
